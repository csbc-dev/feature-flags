{
  "name": "@csbc-dev/feature-flags",
  "version": "0.4.0",
  "description": "Declarative feature flag observation component for Web Components. Server-side flag evaluation, reactive browser-side surface via wc-bindable-protocol.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run test:unit",
    "test:watch": "npm run test:unit:watch",
    "test:coverage": "npm run test:unit:coverage",
    "test:unit": "vitest run __tests__",
    "test:unit:watch": "vitest __tests__",
    "test:unit:coverage": "vitest run __tests__ --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.include=src/**/*.ts --coverage.exclude=src/types.ts --coverage.exclude=src/index.ts --coverage.exclude=src/server/index.ts",
    "test:integration": "npm run build && playwright test"
  },
  "keywords": [
    "web-components",
    "feature-flags",
    "flagsmith",
    "unleash",
    "launchdarkly",
    "custom-elements",
    "wc-bindable",
    "declarative",
    "framework-agnostic"
  ],
  "dependencies": {
    "@wc-bindable/core": "^0.4.0",
    "@wc-bindable/remote": "^0.4.0"
  },
  "peerDependencies": {
    "@launchdarkly/node-server-sdk": "^9.0.0",
    "flagsmith-nodejs": "^5.0.0",
    "unleash-client": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "@launchdarkly/node-server-sdk": {
      "optional": true
    },
    "flagsmith-nodejs": {
      "optional": true
    },
    "unleash-client": {
      "optional": true
    }
  },
  "author": "mogera551",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "happy-dom": "^20.8.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "ws": "^8.20.0"
  }
}
