{
  // Type-check the standalone *.config.ts files (e.g. `vitest.config.ts`)
  // and the test suites, which the production `tsconfig.json`
  // deliberately leaves out of its `include` (its `rootDir` is `src`
  // and its job is to emit `dist/`). This config emits nothing — it is
  // purely a `tsc --noEmit` gate.
  //
  // NOTE: the `__tests__/` suites currently rely on dynamic-mock
  // patterns (`vi.mock` virtual modules, deliberate `as` casts for
  // negative-path inputs) that do not pass `strict` type-checking.
  // `npm run typecheck` therefore checks `src` + the config files
  // today; bringing the test suites under strict checking is tracked
  // as a follow-up. Run `tsc --noEmit -p tsconfig.test.json` with the
  // `__tests__` glob re-added locally to see the outstanding items.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["src", "*.config.ts"]
}
